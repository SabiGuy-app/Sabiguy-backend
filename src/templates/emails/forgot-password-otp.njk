<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ brandName }} Password Reset</title>
</head>
<body style="margin:0; padding:0; background:#f4f7f4; font-family:Arial,Helvetica,sans-serif; color:#1a1a1a;">

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="padding:32px 12px;">
    <tr>
      <td align="center">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:580px;">

          <!-- HERO HEADER -->
          <tr>
            <td style="background:linear-gradient(150deg, #1a6b35 0%, #1d7a3c 55%, #155f2d 100%); border-radius:16px 16px 0 0; padding:36px 36px 30px; text-align:center;">

              {% if logoUrl %}
              <img src="{{ logoUrl }}" alt="{{ brandName }}" style="max-height:52px; width:auto; display:block; margin:0 auto 20px;" />
              {% else %}
              <div style="font-weight:700; font-size:26px; letter-spacing:1px; color:#ffffff; margin-bottom:20px;">{{ brandName }}</div>
              {% endif %}

              <!-- Lock Icon -->
              <div style="display:inline-block; width:56px; height:56px; background:rgba(244,121,32,0.18); border:1.5px solid rgba(244,121,32,0.4); border-radius:50%; text-align:center; line-height:56px; font-size:26px; margin-bottom:18px;">🔐</div>

              <h1 style="margin:0 0 10px; font-size:26px; line-height:1.3; color:#ffffff; font-weight:700;">
                Password Reset Request
              </h1>
              <p style="margin:0; font-size:15px; color:#c8e6c9; line-height:1.65;">
                We received a request to reset your {{ brandName }} password.
              </p>
            </td>
          </tr>

          <!-- ORANGE ACCENT STRIPE -->
          <tr>
            <td style="background:#f47920; height:4px; font-size:0; line-height:0;">&nbsp;</td>
          </tr>

          <!-- MAIN BODY -->
          <tr>
            <td style="background:#ffffff; padding:36px 36px 28px;">

              <p style="margin:0 0 20px; font-size:15.5px; line-height:1.8; color:#374151;">
                Use the one-time code below to reset your <strong style="color:#1a6b35;">{{ brandName }}</strong> account password. Do not share this code with anyone.
              </p>

              <!-- OTP Block -->
              <div style="margin:24px 0; text-align:center;">
                <div style="font-size:12px; letter-spacing:2px; text-transform:uppercase; color:#6b7280; margin-bottom:10px;">Your Reset Code</div>
                <span style="display:inline-block; font-size:32px; letter-spacing:10px; font-weight:700; color:#1a6b35; background:#f0faf3; border:2px solid #86efac; border-radius:12px; padding:14px 24px;">{{ otp }}</span>
                <div style="margin-top:12px; font-size:13.5px; color:#f47920; font-weight:600;">
                  ⏱ Expires in <strong>{{ expiryMinutes }} minutes</strong>
                </div>
              </div>

              <!-- Divider -->
              <div style="border-top:2px solid #f0f0f0; margin:24px 0;"></div>

              <!-- Security Notice -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td width="36" valign="top" style="padding-top:2px;">
                    <div style="font-size:20px;">🛡️</div>
                  </td>
                  <td style="padding-left:12px;">
                    <strong style="display:block; font-size:14px; color:#111827; margin-bottom:4px;">Didn't request this?</strong>
                    <span style="font-size:13.5px; color:#6b7280; line-height:1.7;">
                      No changes have been made to your account. You can safely ignore this email. If you're concerned about your account security, please contact us immediately.
                    </span>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- TIPS BLOCK -->
          <tr>
            <td style="background:#f7fdf8; border-top:1px solid #d1fae5; border-bottom:1px solid #d1fae5; border-left:4px solid #1a6b35; border-right:1px solid #d1fae5; padding:18px 28px;">
              <p style="margin:0 0 8px; font-size:12px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#1a6b35;">
                Security Tips
              </p>
              <ul style="margin:0; padding-left:18px; font-size:13.5px; color:#374151; line-height:2.1;">
                <li>Never share your OTP with anyone, including {{ brandName }} staff.</li>
                <li>Choose a strong password you don't use elsewhere.</li>
                <li>Contact support if you didn't make this request.</li>
              </ul>
            </td>
          </tr>

          <!-- FOOTER -->
          <tr>
            <td style="background:#1a6b35; border-radius:0 0 16px 16px; padding:24px 36px; text-align:center;">

              {% if logoUrl %}
              <img src="{{ logoUrl }}" alt="{{ brandName }}" style="max-height:32px; width:auto; display:block; margin:0 auto 12px; opacity:0.85;" />
              {% else %}
              <div style="font-weight:700; font-size:16px; color:#ffffff; margin-bottom:10px; letter-spacing:1px;">{{ brandName }}</div>
              {% endif %}

              <p style="margin:0 0 6px; font-size:13px; color:#bbf7d0; line-height:1.8;">
                Need help? Reach us at
                <a href="mailto:support@sabiguy.com" style="color:#f9c48a; text-decoration:none; font-weight:600;">support@sabiguy.com</a>
              </p>
              <p style="margin:10px 0 0; font-size:11px; color:#6ee7a0; letter-spacing:0.3px;">
                &copy; {{ year }} Sabiguy. All rights reserved. &nbsp;&middot;&nbsp;
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>