<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ brandName }} Password Changed</title>
</head>
<body style="margin:0; padding:0; background:#f6f8fb; font-family:Arial,Helvetica,sans-serif; color:#1f2937;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="padding:24px 12px;">
    <tr>
      <td align="center">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:560px; background:#ffffff; border-radius:12px; padding:28px; box-shadow:0 2px 8px rgba(16,24,40,0.06);">
          <tr>
            <td align="center" style="padding-bottom:18px;">
              {% if logoUrl %}
              <img src="{{ logoUrl }}" alt="{{ brandName }}" style="max-height:44px; width:auto; display:block;" />
              {% else %}
              <div style="font-weight:700; font-size:22px; letter-spacing:0.2px; color:#111827;">{{ brandName }}</div>
              {% endif %}
            </td>
          </tr>
          <tr>
            <td>
              <h2 style="margin:0 0 10px; font-size:22px; line-height:1.3; color:#0f172a;">Your password was changed</h2>
              <p style="margin:0 0 12px; font-size:15px; line-height:1.6;">Your {{ brandName }} account password was updated successfully.</p>
              <p style="margin:0; font-size:14px; line-height:1.6; color:#4b5563;">If you did not make this change, reset your password immediately and contact support.</p>
            </td>
          </tr>
          <tr>
            <td style="padding-top:22px; font-size:12px; color:#6b7280; text-align:center;">
              {{ brandName }} Team{% if senderEmail %} • {{ senderEmail }}{% endif %}
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
