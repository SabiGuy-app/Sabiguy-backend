<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ brandName }} Password Changed</title>
</head>
<body style="margin:0; padding:0; background:#f4f7f4; font-family:Arial,Helvetica,sans-serif; color:#1a1a1a;">

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="padding:32px 12px;">
    <tr>
      <td align="center">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:580px;">

          <!-- HERO HEADER -->
          <tr>
            <td style="background:linear-gradient(150deg, #1a6b35 0%, #1d7a3c 55%, #155f2d 100%); border-radius:16px 16px 0 0; padding:36px 36px 30px; text-align:center;">

              {% if logoUrl %}
              <img src="{{ logoUrl }}" alt="{{ brandName }}" style="max-height:52px; width:auto; display:block; margin:0 auto 20px;" />
              {% else %}
              <div style="font-weight:700; font-size:26px; letter-spacing:1px; color:#ffffff; margin-bottom:20px;">{{ brandName }}</div>
              {% endif %}

              <!-- Success Icon -->
              <div style="display:inline-block; width:56px; height:56px; background:rgba(134,239,172,0.2); border:1.5px solid rgba(134,239,172,0.5); border-radius:50%; text-align:center; line-height:56px; font-size:26px; margin-bottom:18px;">✅</div>

              <h1 style="margin:0 0 10px; font-size:26px; line-height:1.3; color:#ffffff; font-weight:700;">
                Password Changed Successfully
              </h1>
              <p style="margin:0; font-size:15px; color:#c8e6c9; line-height:1.65;">
                Your {{ brandName }} account password has been updated.
              </p>
            </td>
          </tr>

          <!-- ORANGE ACCENT STRIPE -->
          <tr>
            <td style="background:#f47920; height:4px; font-size:0; line-height:0;">&nbsp;</td>
          </tr>

          <!-- MAIN BODY -->
          <tr>
            <td style="background:#ffffff; padding:36px 36px 28px;">

              <p style="margin:0 0 20px; font-size:15.5px; line-height:1.8; color:#374151;">
                This is a confirmation that the password for your <strong style="color:#1a6b35;">{{ brandName }}</strong> account was successfully changed.
              </p>

              <!-- Confirmation Detail Card -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#f0faf3; border:1.5px solid #86efac; border-radius:10px; margin-bottom:24px;">
                <tr>
                  <td style="padding:18px 20px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td width="28" valign="middle" style="font-size:18px;">🕐</td>
                        <td style="padding-left:10px; font-size:13.5px; color:#374151; vertical-align:middle;">
                          <strong style="color:#1a6b35;">Changed on:</strong> {{ changedAt }}
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Divider -->
              <div style="border-top:2px solid #f0f0f0; margin-bottom:24px;"></div>

              <!-- Warning Notice -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#fff7ed; border:1.5px solid #fed7aa; border-radius:10px;">
                <tr>
                  <td style="padding:18px 20px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td width="28" valign="top" style="font-size:20px; padding-top:2px;">⚠️</td>
                        <td style="padding-left:12px;">
                          <strong style="display:block; font-size:14px; color:#92400e; margin-bottom:5px;">Wasn't you?</strong>
                          <span style="font-size:13.5px; color:#78350f; line-height:1.7;">
                            If you did not make this change, your account may be at risk. Please reset your password immediately and contact our support team.
                          </span>
                          <div style="margin-top:12px;">
                            <a href="mailto:support@sabiguy.com"
                               style="display:inline-block; background:#f47920; color:#ffffff; text-decoration:none; font-size:13px; font-weight:700; padding:9px 20px; border-radius:6px;">
                              Contact Support &rarr;
                            </a>
                          </div>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- TIPS BLOCK -->
          <tr>
            <td style="background:#f7fdf8; border-top:1px solid #d1fae5; border-bottom:1px solid #d1fae5; border-left:4px solid #1a6b35; border-right:1px solid #d1fae5; padding:18px 28px;">
              <p style="margin:0 0 8px; font-size:12px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#1a6b35;">
                Keep Your Account Safe
              </p>
              <ul style="margin:0; padding-left:18px; font-size:13.5px; color:#374151; line-height:2.1;">
                <li>Never share your password with anyone.</li>
                <li>Use a unique password you don't use on other platforms.</li>
                <li>Enable two-factor authentication if available.</li>
              </ul>
            </td>
          </tr>

          <!-- FOOTER -->
          <tr>
            <td style="background:#1a6b35; border-radius:0 0 16px 16px; padding:24px 36px; text-align:center;">

              {% if logoUrl %}
              <img src="{{ logoUrl }}" alt="{{ brandName }}" style="max-height:32px; width:auto; display:block; margin:0 auto 12px; opacity:0.85;" />
              {% else %}
              <div style="font-weight:700; font-size:16px; color:#ffffff; margin-bottom:10px; letter-spacing:1px;">{{ brandName }}</div>
              {% endif %}

              <p style="margin:0 0 6px; font-size:13px; color:#bbf7d0; line-height:1.8;">
                {{ brandName }} Team
                {% if senderEmail %}
                &nbsp;&middot;&nbsp;
                <a href="mailto:{{ senderEmail }}" style="color:#f9c48a; text-decoration:none; font-weight:600;">{{ senderEmail }}</a>
                {% endif %}
              </p>
              <p style="margin:10px 0 0; font-size:11px; color:#6ee7a0; letter-spacing:0.3px;">
                &copy; {{ year }} Sabiguy. All rights reserved. &nbsp;&middot;&nbsp;
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>